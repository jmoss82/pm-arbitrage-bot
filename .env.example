# ── Polymarket ──────────────────────────────────────────────
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_PRIVATE_KEY=
POLY_FUNDER=
CHAIN_ID=137
CLOB_HOST=https://clob.polymarket.com

# ── Kalshi ──────────────────────────────────────────────────
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PEM=
KALSHI_PRIVATE_KEY_BASE64=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_ENV=prod
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2
KALSHI_WS_URL=wss://trading-api.kalshi.com/trade-api/ws/v2

# ── Arbitrage Engine ───────────────────────────────────────
ARB_SCAN_INTERVAL=5
ARB_BTC15_ONLY=true
ARB_MIN_EDGE=0.05
ARB_MAX_POSITION_USD=50.0
ARB_MAX_DAILY_SPEND=500.0
ARB_DRY_RUN=true
ARB_ENABLE_LIVE=false
ARB_REQUIRE_BALANCE_CHECK=true
ARB_MIN_KALSHI_BALANCE_USD=25.0
ARB_MIN_POLY_BALANCE_USD=25.0
ARB_MAX_OPEN_POSITIONS=5

# BTC 15-minute strategy controls
ARB_BTC15_TIME_GATING=true
ARB_ENTRY_MIN_SECONDS_IN_WINDOW=45
ARB_ENTRY_MAX_SECONDS_IN_WINDOW=780
ARB_ENTRY_COOLDOWN_SECONDS_AFTER_ROLLOVER=20
ARB_MIN_EDGE_PERSIST_SCANS=2
ARB_MAX_POLY_OVERROUND=0.04
ARB_MIN_KALSHI_LEVEL_QTY=10
ARB_MAX_SIGNAL_AGE_SECONDS=8

# Limit order / execution controls
ARB_POLY_LIMIT_OFFSET=0.00
ARB_KALSHI_LIMIT_OFFSET_CENTS=0
ARB_ORDER_REPRICE_ATTEMPTS=0
ARB_ORDER_TIMEOUT_SECONDS=4
ARB_ALLOW_PARTIAL_FILLS=false
ARB_ENTRY_MARKETABLE=true
ARB_POLY_ENTRY_AGGRESSION=0.01
ARB_KALSHI_ENTRY_AGGRESSION_CENTS=1
ARB_EXIT_LIMIT_ONLY=true
ARB_POLY_EXIT_PASSIVE_OFFSET=0.01
ARB_KALSHI_EXIT_PASSIVE_OFFSET_CENTS=1

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
